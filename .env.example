DATABASE_URL="postgresql://racedz:racedz@localhost:5432/racedz"
AUTH_SECRET="change-me"
AUTH_URL="http://127.0.0.1:3003"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://127.0.0.1:3003"

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

NEXT_PUBLIC_APP_NAME="ZidRun"
NEXT_PUBLIC_APP_TAGLINE="Find, register, and manage races across Algeria."

UPLOAD_PROVIDER="local"

ADMIN_AUDIT_RETENTION_DAYS="31"

# Future S3
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Email notifications
EMAIL_PROVIDER="resend"
EMAIL_FROM="ZidRun <notifications@zidrun.com>"
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# Push notifications
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Runner AI coach (server only)
OPENAI_API_KEY=""
OPENAI_COACH_MODEL="gpt-5.4-mini"
OPENAI_TRANSCRIBE_MODEL="whisper-1"
# Admin "import race from social post" — vision model that reads the poster/caption. Must be
# multimodal; defaults to OPENAI_COACH_MODEL's family when unset.
SOCIAL_IMPORT_MODEL="gpt-5.4-mini"
COACH_DAILY_AI_LIMIT="20"
COACH_MONTHLY_AI_LIMIT="100"

# Error monitoring (Sentry) — optional; leave empty to disable
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Shared secret for internal scheduled jobs (POST /api/internal/cron/*). Set to a long random
# value and have an external scheduler send it as `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=""
# Coach inactivity nudge tuning (optional; defaults shown).
COACH_INACTIVITY_DAYS="5"
COACH_INACTIVITY_GRACE_DAYS="5"
COACH_INACTIVITY_COOLDOWN_DAYS="6"
