zidrun.com, www.zidrun.com {
	encode zstd gzip

	# Coach payment proofs are financial PII (BaridiMob/CCP screenshots). They live in the same
	# uploads volume but must NEVER be served publicly — only the app's authenticated route
	# /api/coach/subscription/proof/* serves them, to the owner or an admin. This block comes first
	# so it wins over the general /uploads/* handler below.
	handle /uploads/coach-payment/* {
		respond 403
	}

	# User uploads are written to a runtime volume by the app and served straight
	# from disk here (next start won't serve runtime-written public/ files).
	# handle_path strips the /uploads prefix, so /uploads/avatar/x.jpg maps to
	# /srv/uploads/avatar/x.jpg.
	handle_path /uploads/* {
		root * /srv/uploads
		# User-supplied content served straight from disk. Even though uploads are
		# validated by magic bytes on write, harden the response so a stored file can
		# never be sniffed into an executable type or run script/plugins in the origin:
		#   - nosniff pins the declared Content-Type (no MIME sniffing)
		#   - the sandbox CSP strips scripts, forms, and same-origin privileges
		#   - deny framing to block clickjacking via an uploaded page
		header {
			X-Content-Type-Options "nosniff"
			Content-Security-Policy "default-src 'none'; img-src 'self'; style-src 'unsafe-inline'; sandbox"
			X-Frame-Options "DENY"
			Cache-Control "public, max-age=31536000, immutable"
		}
		file_server
	}

	# Public Android app download. Served from a subfolder of the same uploads volume
	# (so the ~7 MB APK stays out of git and the Docker image) with the correct Android
	# package MIME type so phones install it directly. handle_path strips the prefix, so
	# /app/downloads/zidrunapk.apk maps to /srv/uploads/app-downloads/zidrunapk.apk.
	handle_path /app/downloads/* {
		root * /srv/uploads/app-downloads
		header {
			Content-Type "application/vnd.android.package-archive"
			Content-Disposition "attachment; filename=\"zidrunapk.apk\""
			# Short cache so a re-uploaded APK propagates within the hour.
			Cache-Control "public, max-age=3600"
		}
		file_server
	}

	# Everything else goes to the Next.js app.
	handle {
		reverse_proxy app:3003
	}
}
