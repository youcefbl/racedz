generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  firstName       String
  lastName        String
  arabicFullName  String?
  phone           String?
  role            UserRole  @default(RUNNER)
  gender          Gender?
  dateOfBirth     DateTime?
  nationalId      String?   @unique
  avatarUrl       String?
  wilaya          String?
  city            String?
  commune         String?
  emailVerifiedAt DateTime?
  blockedAt       DateTime?
  firstLoginAt    DateTime?
  lastLoginAt     DateTime?
  onboardedAt     DateTime? // set once the runner finishes (or skips) the first-login welcome step
  language        String? // saved UI language ("en" | "fr" | "ar"), synced across devices
  theme           String? // saved appearance ("light" | "dark" | "race"), synced across devices
  profilePrivate  Boolean   @default(false) // opt-in: hide from public leaderboards, others' feeds, and following
  mfaEnabled      Boolean   @default(false) // TOTP two-factor active (opt-in; primarily for admins)
  mfaSecret       String? // base32 TOTP secret, server-only; set while enrolled
  mfaBackupCodes  String[]  @default([]) // sha256 hashes of one-time recovery codes
  mfaEnabledAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizations               OrganizationMember[]
  organizationInvitationsSent OrganizationInvitation[]
  emailVerificationTokens     EmailVerificationToken[]
  passwordResetTokens         PasswordResetToken[]
  nativeAuthTokens            NativeAuthToken[]
  registrations               RaceRegistration[]
  raceEditHistory             RaceEditHistory[]
  adminAuditLogs              AdminAuditLog[]
  notifications               Notification[]
  notificationPreferences     NotificationPreference[]
  pushSubscriptions           PushSubscription[]
  raceAnnouncements           RaceAnnouncement[]
  runnerGoals                 RunnerGoal[]
  runnerRuns                  RunnerRun[]
  trainingPlans               TrainingPlan[]
  coachSnapshots              CoachSnapshot[]
  coachInteractions           CoachInteraction[]
  aiUsageLogs                 AiUsageLog[]
  coachSubscriptions          CoachSubscription[]
  coachSubscriptionRequests   CoachSubscriptionRequest[]
  sleepLogs                   SleepLog[]
  supportThreads              SupportThread[]
  following                   Follow[]                   @relation("Following")
  followers                   Follow[]                   @relation("Followers")
  runKudos                    RunKudos[]
  raceResults                 RaceResult[]
  nutritionEntries            NutritionEntry[]
}

enum UserRole {
  RUNNER
  ORGANIZER
  ADMIN
  SUPERADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Organization {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  email           String?
  phone           String?
  website         String?
  facebookUrl     String?
  instagramUrl    String?
  logoUrl         String?
  wilaya          String?
  city            String?
  commune         String?
  status          OrganizationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  members     OrganizationMember[]
  invitations OrganizationInvitation[]
  races       RaceEvent[]
}

enum OrganizationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model OrganizationMember {
  id             String        @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizerRole @default(MEMBER)
  createdAt      DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

enum OrganizerRole {
  OWNER
  ADMIN
  MEMBER
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           OrganizerRole    @default(MEMBER)
  status         InvitationStatus @default(PENDING)
  invitedById    String
  token          String           @unique
  createdAt      DateTime         @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation(fields: [invitedById], references: [id])

  @@unique([organizationId, email])
  @@index([email])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model RaceEvent {
  id                         String                  @id @default(cuid())
  organizationId             String?
  source                     RaceSource              @default(ORGANIZATION)
  title                      String
  slug                       String                  @unique
  description                String
  elevationGainText          String?
  conditions                 String?
  raceType                   RaceType
  status                     RaceStatus              @default(DRAFT)
  registrationStatus         EventRegistrationStatus @default(NOT_OPEN)
  startDate                  DateTime
  endDate                    DateTime?
  registrationOpenAt         DateTime?
  registrationCloseAt        DateTime?
  wilaya                     String
  city                       String
  commune                    String?
  address                    String?
  latitude                   Float?
  longitude                  Float?
  mainImageUrl               String?
  organizerName              String?
  organizerUrl               String?
  rules                      String?
  requiredDocuments          String?
  contactEmail               String?
  contactPhone               String?
  baridiMobNumber            String?
  ccpAccount                 String?
  ccpKey                     String?
  paymentNote                String?
  maxParticipants            Int?
  availablePlaces            Int?
  autoCancelUnpaidAfterHours Int?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  organization  Organization?      @relation(fields: [organizationId], references: [id])
  categories    RaceCategory[]
  registrations RaceRegistration[]
  editHistory   RaceEditHistory[]
  announcements RaceAnnouncement[]
  coachGoals    RunnerGoal[]
  results       RaceResult[]
}

enum RaceSource {
  ORGANIZATION
  PLATFORM
}

enum RaceType {
  ROAD
  TRAIL
  ULTRA_TRAIL
  MARATHON
  HALF_MARATHON
  TEN_K
  FIVE_K
  KIDS
  CHARITY
  OTHER
}

enum RaceStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  CANCELLED
  COMPLETED
  REJECTED
}

enum EventRegistrationStatus {
  NOT_OPEN
  OPEN
  CLOSED
  FULL
  CANCELLED
}

model RaceCategory {
  id              String    @id @default(cuid())
  raceEventId     String
  name            String
  raceType        RaceType?
  distanceKm      Float
  elevationGainM  Int?
  priceDzd        Int?
  maxParticipants Int?
  minAge          Int?
  maxAge          Int?
  startTime       DateTime?
  cutoffTimeMin   Int?
  gpxFileUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  raceEvent     RaceEvent          @relation(fields: [raceEventId], references: [id])
  registrations RaceRegistration[]
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([createdAt])
}

// First-party, privacy-conscious web analytics. One row per page view.
// No raw IP is ever stored: `country` comes from Cloudflare's cf-ipcountry header,
// and visitors are identified only by opaque first-party cookies (zr_vid / zr_sid).
// Raw rows are pruned after PAGEVIEW_RETENTION_DAYS (see scripts/prune-pageviews.ts),
// mirroring the AdminAuditLog retention model above.
model PageView {
  id           String   @id @default(cuid())
  visitorId    String // opaque cookie (zr_vid) — stable ~1yr, powers unique-visitor counts
  sessionId    String // opaque cookie (zr_sid) — 30-min rolling window, powers session counts
  userId       String? // best-effort from the auth session; null for anonymous visitors
  path         String // normalized route pattern, e.g. "/races/[id]" (keeps cardinality low)
  referrerHost String? // referrer host only — no full URL or query string
  locale       String? // en | fr | ar
  device       String? // mobile | tablet | desktop
  platform     String? // web | android (Capacitor native app)
  browser      String? // coarse family: Chrome | Safari | Firefox | Edge | Other
  country      String? // ISO-2 country from cf-ipcountry (no raw IP retained)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([visitorId, createdAt])
  @@index([sessionId])
  @@index([userId, createdAt])
}

model RaceRegistration {
  id                    String             @id @default(cuid())
  userId                String
  raceEventId           String
  raceCategoryId        String
  bibNumber             String?
  status                RegistrationStatus @default(PENDING)
  paymentStatus         PaymentStatus      @default(PENDING)
  paymentMethod         PaymentMethod?
  paymentProofUrl       String?
  emergencyContactName  String
  emergencyContactPhone String
  clubName              String?
  tshirtSize            String?
  medicalCertificateUrl String?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  raceEvent    RaceEvent    @relation(fields: [raceEventId], references: [id])
  raceCategory RaceCategory @relation(fields: [raceCategoryId], references: [id])
  result       RaceResult?

  @@unique([userId, raceCategoryId])
}

model RaceEditHistory {
  id          String   @id @default(cuid())
  raceEventId String
  editorId    String
  action      String
  summary     String?
  changes     Json
  createdAt   DateTime @default(now())

  raceEvent RaceEvent @relation(fields: [raceEventId], references: [id])
  editor    User      @relation(fields: [editorId], references: [id])

  @@index([raceEventId, createdAt])
  @@index([editorId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

// Short-lived, single-use token that bridges a web (system-browser) Google sign-in
// into the native app's webview session. Minted at /auth/native/handoff after a
// successful OAuth login, delivered via the zidrun://auth deep link, then consumed
// by the "native-bridge" credentials provider. See src/lib/native-auth.ts.
model NativeAuthToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model RaceAnnouncement {
  id          String   @id @default(cuid())
  raceEventId String
  authorId    String
  title       String
  body        String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  raceEvent RaceEvent @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  @@index([raceEventId, publishedAt])
  @@index([authorId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user       User                   @relation(fields: [userId], references: [id])
  deliveries NotificationDelivery[]

  @@index([userId, readAt, createdAt])
  @@index([type, createdAt])
}

model NotificationDelivery {
  id                String    @id @default(cuid())
  notificationId    String
  channel           String
  status            String    @default("PENDING")
  provider          String
  providerMessageId String?
  error             String?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  notification Notification @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@index([channel, status, createdAt])
}

model PushSubscription {
  id          String    @id @default(cuid())
  userId      String
  provider    String    @default("firebase")
  token       String    @unique
  deviceLabel String?
  lastSeenAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String
  type         String
  inAppEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  emailEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
  WAITING_LIST
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
  REFUNDED
  MANUAL_REVIEW
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  BARIDIMOB
  CCP
  ONLINE_CARD
  OTHER
}

model RunnerGoal {
  id                      String           @id @default(cuid())
  userId                  String
  raceEventId             String?
  goalType                CoachGoalType
  customGoal              String?
  targetDate              DateTime
  targetDistanceKm        Float?
  targetTimeSeconds       Int?
  experienceLevel         RunnerExperience
  currentWeeklyDistanceKm Float
  yearsRunning            Int?
  peakWeeklyDistanceKm    Float?
  longestRecentRunKm      Float?
  recentRaceResult        String?
  restingHeartRate        Int?
  weightKg                Float?
  heightCm                Int?
  availableTrainingDays   Int[]
  preferredLongRunDay     Int?
  constraints             String?
  injuryNotes             String?
  injuryHistory           String?
  chronicConditions       String[]         @default([])
  healthNotes             String?
  preferredLocale         String           @default("en")
  status                  CoachGoalStatus  @default(ACTIVE)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  raceEvent    RaceEvent?         @relation(fields: [raceEventId], references: [id], onDelete: SetNull)
  runs         RunnerRun[]
  plans        TrainingPlan[]
  snapshots    CoachSnapshot[]
  interactions CoachInteraction[]

  @@index([userId, status])
  @@index([raceEventId])
}

model RunnerRun {
  id                      String          @id @default(cuid())
  userId                  String
  goalId                  String?
  workoutId               String?         @unique
  startedAt               DateTime
  distanceKm              Float
  durationSeconds         Int
  averagePaceSecondsPerKm Int
  movingTimeSeconds       Int?
  elevationGainM          Int?
  averageHeartRate        Int?
  avgCadence              Int?
  calories                Int?
  route                   Json?
  weather                 Json?
  isPublic                Boolean         @default(false)
  perceivedEffort         Int
  fatigueLevel            Int             @default(0)
  painLevel               Int             @default(0)
  title                   String?
  symptoms                String?
  notes                   String?
  photos                  Json?
  source                  RunnerRunSource @default(MANUAL)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal         RunnerGoal?        @relation(fields: [goalId], references: [id], onDelete: SetNull)
  workout      TrainingWorkout?   @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  interactions CoachInteraction[]
  kudos        RunKudos[]

  @@index([userId, startedAt])
  @@index([goalId, startedAt])
}

model TrainingPlan {
  id        String             @id @default(cuid())
  userId    String
  goalId    String
  version   Int
  startsOn  DateTime
  endsOn    DateTime
  status    TrainingPlanStatus @default(DRAFT)
  source    TrainingPlanSource @default(AI_ASSISTED)
  summary   String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal     RunnerGoal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workouts TrainingWorkout[]

  @@unique([goalId, version])
  @@index([userId, status, startsOn])
}

model TrainingWorkout {
  id                String           @id @default(cuid())
  trainingPlanId    String
  scheduledFor      DateTime
  workoutType       CoachWorkoutType
  title             String
  targetDistanceKm  Float?
  targetDurationMin Int?
  intensity         String
  instructions      String
  status            WorkoutStatus    @default(PLANNED)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  trainingPlan TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  completedRun RunnerRun?

  @@index([trainingPlanId, scheduledFor])
}

model CoachSnapshot {
  id          String   @id @default(cuid())
  userId      String
  goalId      String?
  metrics     Json
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal RunnerGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@unique([userId])
  @@index([goalId])
}

// One night's sleep for a runner, one row per calendar night (upserted). durationMinutes is the
// canonical value the coach reads; bedTime/wakeTime are optional "HH:MM" strings kept for display
// when the runner entered times rather than a duration. `source` records whether it was entered
// directly or parsed from free text by the AI.
model SleepLog {
  id              String         @id @default(cuid())
  userId          String
  night           DateTime       @db.Date
  durationMinutes Int
  bedTime         String?
  wakeTime        String?
  note            String?
  source          SleepLogSource @default(MANUAL)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, night])
  @@index([userId, night])
}

model CoachInteraction {
  id            String                 @id @default(cuid())
  userId        String
  goalId        String?
  runId         String?
  type          CoachInteractionType
  status        CoachInteractionStatus @default(PENDING)
  userMessage   String?
  response      Json?
  safety        Json
  // For HUMAN_NOTE interactions: the admin/coach who wrote the note (null for AI-generated ones).
  authorId      String?
  model         String?
  promptVersion String
  errorCode     String?
  acceptedAt    DateTime?
  createdAt     DateTime               @default(now())
  completedAt   DateTime?

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal      RunnerGoal?  @relation(fields: [goalId], references: [id], onDelete: SetNull)
  run       RunnerRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  usageLogs AiUsageLog[]

  @@index([userId, createdAt])
  @@index([goalId, type, createdAt])
  @@index([runId])
}

model AiUsageLog {
  id                    String          @id @default(cuid())
  userId                String
  interactionId         String?
  provider              String          @default("openai")
  providerResponseId    String?
  model                 String
  status                AiRequestStatus
  inputTokens           Int             @default(0)
  cachedInputTokens     Int             @default(0)
  outputTokens          Int             @default(0)
  reasoningTokens       Int             @default(0)
  estimatedCostMicroUsd Int             @default(0)
  errorCode             String?
  errorMessage          String?
  createdAt             DateTime        @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  interaction CoachInteraction? @relation(fields: [interactionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([interactionId])
  @@index([status, createdAt])
}

model CoachSubscription {
  id              String                  @id @default(cuid())
  userId          String
  plan            CoachSubscriptionPlan
  status          CoachSubscriptionStatus @default(ACTIVE)
  months          Int
  amountDa        Int?
  note            String?
  // Whether this subscription includes human-coach review (a real coach posts personal notes),
  // on top of the AI coach. Granted by an admin when activating/editing the subscription.
  humanCoaching   Boolean                 @default(false)
  startedAt       DateTime                @default(now())
  expiresAt       DateTime
  createdByUserId String?
  cancelledAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, expiresAt])
}

// A runner-submitted subscription request with uploaded payment proof, awaiting admin review.
// Kept separate from CoachSubscription so that model keeps meaning "an actual paid entitlement":
// approving a request calls activateCoachSubscription() to mint the real subscription row.
model CoachSubscriptionRequest {
  id               String                         @id @default(cuid())
  userId           String
  plan             CoachSubscriptionPlan
  amountDa         Int?
  paymentMethod    String?
  paymentProofUrl  String
  note             String?
  status           CoachSubscriptionRequestStatus @default(PENDING)
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNote       String?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

enum CoachSubscriptionPlan {
  MONTHLY
  YEARLY
  CUSTOM
}

enum CoachSubscriptionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CoachSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum CoachGoalType {
  GENERAL_FITNESS
  FIVE_K
  TEN_K
  HALF_MARATHON
  MARATHON
  TRAIL
  OTHER
}

enum RunnerExperience {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CoachGoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum RunnerRunSource {
  MANUAL
  IMPORTED
  GPS
}

enum SleepLogSource {
  MANUAL
  PARSED
}

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  COMPLETED
  CANCELLED
}

enum TrainingPlanSource {
  RULE_BASED
  AI_ASSISTED
  MANUAL
}

enum CoachWorkoutType {
  EASY
  LONG_RUN
  TEMPO
  INTERVAL
  RECOVERY
  REST
  CROSS_TRAINING
  RACE
}

enum WorkoutStatus {
  PLANNED
  COMPLETED
  SKIPPED
  CANCELLED
}

enum CoachInteractionType {
  INITIAL_PLAN
  POST_RUN
  WEEKLY_REVIEW
  CHAT
  HUMAN_NOTE
}

enum CoachInteractionStatus {
  PENDING
  COMPLETED
  BLOCKED
  FAILED
}

enum AiRequestStatus {
  SUCCEEDED
  FAILED
}

// Coaching "tips" shown to runners on the coach dashboard. Stored per-language
// (textEn/textFr/textAr) following the app's sibling-column localization convention.
// AI-proposed tips land as PROPOSED for an admin to review, edit, then PUBLISH.
model CoachTip {
  id              String           @id @default(cuid())
  category        CoachTipCategory
  status          CoachTipStatus   @default(PROPOSED)
  source          CoachTipSource   @default(MANUAL)
  textEn          String
  textFr          String
  textAr          String
  proposedByModel String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, category])
}

enum CoachTipCategory {
  GENERAL
  BEGINNER
  INTERMEDIATE
  EXPERIENCED
  HEAVY_WEIGHT
  MARATHON
  SPEED
  TRAIL
  FITNESS
  INJURY_PRONE
}

enum CoachTipStatus {
  PROPOSED
  PUBLISHED
  REJECTED
}

enum CoachTipSource {
  MANUAL
  AI
}

// User-submitted moderation reports. Generic target (targetType/targetId) so races,
// public runs, and profiles can all be reported without a schema change; v1 only
// surfaces a report control on race pages. Admin triages via /admin/reports.
enum ReportCategory {
  SCAM
  SPAM
  OFFENSIVE
  INCORRECT_INFO
  OTHER
}

enum ReportStatus {
  OPEN
  ACTIONED
  DISMISSED
}

model Report {
  id             String         @id @default(cuid())
  reporterId     String
  targetType     String // "RaceEvent" | "RunnerRun" | "User" (extensible)
  targetId       String
  category       ReportCategory
  details        String?
  status         ReportStatus   @default(OPEN)
  resolvedById   String? // admin who actioned/dismissed
  resolutionNote String?
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId, createdAt])
}

// Admin broadcast/announcement to a user segment. Fan-out is resumable: recipients
// are snapshotted into BroadcastRecipient rows and drained in batches (inline kick +
// a CRON_SECRET-guarded dispatch endpoint) so a large send can't time out a request.
enum BroadcastStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

model Broadcast {
  id              String          @id @default(cuid())
  title           String
  body            String
  href            String?
  channels        String[] // subset of IN_APP | EMAIL | PUSH
  audience        Json // segment filter descriptor (see src/lib/broadcasts.ts)
  status          BroadcastStatus @default(DRAFT)
  totalRecipients Int             @default(0)
  sentCount       Int             @default(0)
  failedCount     Int             @default(0)
  createdById     String
  createdAt       DateTime        @default(now())
  sentAt          DateTime?

  recipients BroadcastRecipient[]

  @@index([status, createdAt])
  @@index([createdAt])
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  userId      String
  status      String    @default("PENDING") // PENDING | SENT | FAILED
  error       String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId])
  @@index([broadcastId, status])
}

// Race-search log powering the "zero-result search" report — the term lives in the
// ?q= querystring that the PageView tracker deliberately drops, so it needs its own
// table. Written server-side from the races page; deduped per visitor over 30 min.
// Covered by retention pruning (scripts/prune-pageviews.ts).
model SearchQuery {
  id          String   @id @default(cuid())
  term        String
  wilaya      String?
  raceType    String?
  resultCount Int
  visitorId   String?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([term])
  @@index([resultCount, createdAt])
}

// One direct-message thread between a runner and the admin/support team. Kept as a single
// open thread per user (created lazily on their first message). Read state is tracked with
// two "last read" timestamps rather than per-message flags: unread = messages from the other
// party created after the reader's own lastReadAt. Polling-based (no websockets on this stack).
model SupportThread {
  id              String              @id @default(cuid())
  userId          String
  subject         String?
  status          SupportThreadStatus @default(OPEN)
  lastMessageAt   DateTime            @default(now())
  userLastReadAt  DateTime?
  adminLastReadAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([status, lastMessageAt])
  @@index([userId])
}

model SupportMessage {
  id        String   @id @default(cuid())
  threadId  String
  // The sender's user id. fromAdmin distinguishes a support reply from the runner's message
  // without needing a join back to User just to render the bubble side.
  authorId  String
  fromAdmin Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

enum SupportThreadStatus {
  OPEN
  CLOSED
}

// A directed follow edge: `follower` follows `following`. Powers the activity feed (public runs
// from people you follow) and follower/following counts on profiles.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

// A "kudos" (like) on a public run. One per (run, user). Deleting the row un-kudos.
model RunKudos {
  id        String   @id @default(cuid())
  runId     String
  userId    String
  createdAt DateTime @default(now())

  run  RunnerRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([runId, userId])
  @@index([userId])
}

// The outcome of a race for one registered runner: finish time, status, and rankings. Recorded by
// the organizer/admin after the event. Closes the race loop — turns a registration into a
// permanent finisher record on the runner's profile.
model RaceResult {
  id                String           @id @default(cuid())
  registrationId    String           @unique
  eventId           String
  userId            String
  finishTimeSeconds Int?
  status            RaceResultStatus @default(FINISHED)
  overallRank       Int?
  categoryRank      Int?
  notes             String?
  recordedById      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  registration RaceRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event        RaceEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
}

enum RaceResultStatus {
  FINISHED
  DNF // did not finish
  DNS // did not start
  DSQ // disqualified
}

// A fuel/hydration log entry for a given day. Feeds the AI coach's context (fueling around long
// runs, race week) and a simple daily-intake view. Deliberately light: free-text meal + optional
// calories, or a hydration amount.
model NutritionEntry {
  id          String   @id @default(cuid())
  userId      String
  loggedFor   DateTime // the day the entry applies to (date-only semantics, stored at UTC midnight)
  kind        String   @default("MEAL") // MEAL | HYDRATION
  mealType    String? // BREAKFAST | LUNCH | DINNER | SNACK (for MEAL)
  description String?
  calories    Int?
  waterMl     Int? // for HYDRATION
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedFor])
}
