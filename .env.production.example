# Shared secret for internal scheduled jobs (POST /api/internal/cron/*).
# Generate with: openssl rand -hex 32
CRON_SECRET=
COACH_INACTIVITY_DAYS=5
COACH_INACTIVITY_GRACE_DAYS=5
COACH_INACTIVITY_COOLDOWN_DAYS=6
# Coach nudge scheduler (the `cron` service in docker-compose.prod.yml). Optional overrides.
CRON_TZ=UTC
COACH_NUDGE_CRON=0 17 * * *
COACH_NUDGE_URL=http://app:3003/api/internal/cron/inactivity-nudge
