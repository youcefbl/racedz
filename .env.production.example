POSTGRES_PASSWORD=change-this-long-random-password

AUTH_SECRET=change-this-long-random-secret
AUTH_URL=https://zidrun.com
NEXTAUTH_SECRET=change-this-long-random-secret
NEXTAUTH_URL=https://zidrun.com

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

NEXT_PUBLIC_APP_NAME=ZidRun
NEXT_PUBLIC_APP_TAGLINE=Find, register, and manage races across Algeria.

UPLOAD_PROVIDER=local
